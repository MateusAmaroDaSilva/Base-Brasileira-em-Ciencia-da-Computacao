# ============================================================================
# .env.example - Variáveis de Ambiente
# Copie para .env e ajuste conforme necessário
# ============================================================================

# ============= AMBIENTE =============
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production-12345

# ============= BANCO DE DADOS =============
DATABASE_URL=postgresql://dev_user:dev_password_123@postgres:5432/base_computacao
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ============= REDIS =============
REDIS_URL=redis://:redis_password_123@redis:6379/0
REDIS_CACHE_EXPIRE=3600
REDIS_CACHE_KEY_PREFIX=base_computacao:

# ============= ELASTICSEARCH =============
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_VERIFY_CERTS=False
ELASTICSEARCH_INDEX_NAME=articles
ELASTICSEARCH_BULK_SIZE=500

# ============= CELERY (Task Queue) =============
CELERY_BROKER_URL=redis://:redis_password_123@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_password_123@redis:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_RESULT_SERIALIZER=json

# Schedules (cron)
CELERY_SYNC_INTERVAL_HOURS=24  # Sincronizar a cada 24 horas
CELERY_INDEX_INTERVAL_MINUTES=30

# ============= OAI-PMH EXTRACTOR =============
OAI_REQUEST_TIMEOUT=30
OAI_RETRY_ATTEMPTS=3
OAI_RETRY_BACKOFF=2
OAI_BATCH_SIZE=100
OAI_USE_RESUMPTION_TOKEN=True

# Nota: Revistas são cadastradas automaticamente no banco de dados
# Não edite esta seção

# ============= LOGGING =============
LOG_LEVEL=INFO
LOG_FORMAT=json
QUERY_LOGGING=False
QUERY_LOG_FILE=logs/queries.log

# ============= API =============
API_TITLE=Base Brasileira em Ciência da Computação
API_DESCRIPTION=Plataforma de busca e extração de publicações brasileiras de computação
API_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============= FRONTEND =============
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=30000
VITE_ENVIRONMENT=development

# ============= SEGURANÇA (Produção) =============
# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# CORS
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_STORAGE=redis

# ============= EMAIL (Notificações) =============
MAIL_ENABLED=False
MAIL_FROM_ADDRESS=noreply@base-computacao.br
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=

# ============= MONITORING & OBSERVABILITY =============
SENTRY_ENABLED=False
SENTRY_DSN=

PROMETHEUS_ENABLED=False
PROMETHEUS_PORT=9090

# ============= STORAGE (Para PDFs, etc) =============
STORAGE_TYPE=local  # local, s3, gcs
STORAGE_PATH=/app/storage
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=

# ============= BACKUP =============
BACKUP_ENABLED=False
BACKUP_SCHEDULE="0 2 * * *"  # 2am todo dia
BACKUP_RETENTION_DAYS=30

# ============= FEATURES FLAGS =============
FEATURE_ADVANCED_SEARCH=True
FEATURE_BOOLEAN_OPERATORS=True
FEATURE_FACETED_SEARCH=True
FEATURE_SAVED_SEARCHES=False
FEATURE_EXPORT_RESULTS=False
FEATURE_ADMIN_PANEL=True

# ============= DEVELOPMENT =============
# Apenas para desenvolvimento local
SQLALCHEMY_ECHO=False
PYTEST_ADDOPTS=--strict-markers -v
WORKERS_COUNT=1

# ============================================================================
# NOTAS:
# - Não commite este arquivo em Git
# - Para produção, use variáveis de ambiente do sistema
# - Mude todos os passwords e keys
# - Use HTTPS em produção
# - Configure CORS_ORIGINS com domínios reais
# ============================================================================
